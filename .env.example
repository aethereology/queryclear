# queryclear environment variables — copy to .env.local and fill in.
# Lead emails are sent via Resend. Until RESEND_API_KEY is set, leads are still
# captured (logged server-side) but not emailed.

# 1) Sign up at https://resend.com and create an API key:
RESEND_API_KEY=

# 2) Where audit requests are emailed (defaults to the contact email in lib/site.ts):
LEAD_TO=aethelo@sparkcreativesinc.org

# 3) Verified sender. For quick testing you can use Resend's sandbox sender
#    (onboarding@resend.dev — only delivers to your Resend account email).
#    For production, verify queryclear.com in Resend and use e.g. leads@queryclear.com:
LEAD_FROM=queryclear <onboarding@resend.dev>
